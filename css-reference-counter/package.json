{
  "name": "css-reference-counter-and-peek",
  "displayName": "CSS Reference Counter and Peek",
  "description": "Shows how many times each CSS selector is used across your project with CodeLens annotations, Ctrl+Click navigation, and Find All References.",
  "version": "1.0.4",
  "publisher": "JatinShimpi",
  "icon": "icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/JatinShimpi/css-reference-counter"
  },
  "keywords": [
    "css",
    "scss",
    "references",
    "codelens",
    "peek",
    "unused css",
    "dead code"
  ],
  "galleryBanner": {
    "color": "#1e1e2e",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:css",
    "onLanguage:scss",
    "onLanguage:html",
    "onLanguage:javascriptreact",
    "onLanguage:typescriptreact",
    "onLanguage:vue",
    "onLanguage:svelte"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "cssReferenceCounter.rescan",
        "title": "CSS Reference Counter: Rescan Workspace",
        "icon": "$(refresh)"
      },
      {
        "command": "cssReferenceCounter.addExcludePattern",
        "title": "CSS Reference Counter: Add Exclude Pattern",
        "icon": "$(add)"
      },
      {
        "command": "cssReferenceCounter.removeExcludePattern",
        "title": "CSS Reference Counter: Remove Exclude Pattern",
        "icon": "$(trash)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "cssReferenceCounter",
          "title": "CSS Reference Counter",
          "icon": "images/sidebar-icon.svg"
        }
      ]
    },
    "views": {
      "cssReferenceCounter": [
        {
          "id": "cssReferenceCounter.sidebar",
          "name": "CSS References"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "cssReferenceCounter.rescan",
          "when": "view == cssReferenceCounter.sidebar",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "cssReferenceCounter.removeExcludePattern",
          "when": "view == cssReferenceCounter.sidebar && viewItem == excludePatternItem",
          "group": "inline"
        },
        {
          "command": "cssReferenceCounter.addExcludePattern",
          "when": "view == cssReferenceCounter.sidebar && viewItem == excludeSection",
          "group": "inline"
        }
      ]
    },
    "configuration": {
      "title": "CSS Reference Counter",
      "properties": {
        "cssReferenceCounter.includedFileTypes": {
          "type": "array",
          "default": [
            "html",
            "htm",
            "jsx",
            "tsx",
            "vue",
            "svelte",
            "js",
            "ts"
          ],
          "description": "File extensions to scan for CSS class/id usage."
        },
        "cssReferenceCounter.excludePatterns": {
          "type": "array",
          "default": [
            "**/node_modules/**",
            "**/dist/**",
            "**/build/**",
            "**/.git/**",
            "**/target/**",
            "**/out/**",
            "**/vendor/**",
            "**/bower_components/**",
            "**/.next/**",
            "**/.nuxt/**",
            "**/coverage/**",
            "**/__pycache__/**",
            "**/.venv/**",
            "**/*.min.js",
            "**/*.min.css",
            "**/.svelte-kit/**",
            "**/.angular/**",
            "**/.cache/**",
            "**/tmp/**",
            "**/public/assets/**"
          ],
          "description": "Glob patterns to exclude from scanning."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  }
}